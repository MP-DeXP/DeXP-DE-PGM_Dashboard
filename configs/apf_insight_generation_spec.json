{
  "version": "1.0.0",
  "mode_default": "aggregated_fallback",
  "inputs": [
    "brand_score.csv",
    "anchor_scored.csv",
    "anchor_transition.csv",
    "cart_anchor.csv",
    "cart_anchor_detail.csv"
  ],
  "outputs": [
    {
      "filename": "aa_cohort_journey.csv",
      "required_columns": [
        "cohort_date",
        "aa_product_id",
        "aa_type",
        "cohort_customers",
        "repeat_7d_rate",
        "repeat_30d_rate",
        "repeat_90d_rate",
        "pca_transition_30d_rate",
        "pca_transition_90d_rate",
        "avg_days_to_pca",
        "avg_revenue_90d"
      ],
      "rules": [
        "cohort_date: generation_date(YYYY-MM-DD)",
        "aa_product_id: from anchor_scored.product_id",
        "aa_type: from anchor_scored.AA_Primary_Type, fallback Unknown",
        "cohort_customers: from anchor_scored.first_customer_cnt",
        "repeat_90d_rate: from anchor_scored.repurchase_rate_90d",
        "repeat_30d_rate: repeat_90d_rate * 0.72 (fallback mode)",
        "repeat_7d_rate: repeat_30d_rate * 0.55 (fallback mode)",
        "pca_transition_90d_rate: prefer anchor_transition aggregate(trans_customer/cohort), fallback repeat_90d_rate * 0.70",
        "pca_transition_30d_rate: pca_transition_90d_rate * 0.62",
        "avg_revenue_90d: revenue_90d / first_customer_cnt"
      ]
    },
    {
      "filename": "aa_transition_path.csv",
      "required_columns": [
        "cohort_date",
        "aa_product_id",
        "aa_type",
        "pca_product_id",
        "transition_customers",
        "transition_rate",
        "avg_days_to_pca"
      ],
      "rules": [
        "cohort_date: generation_date(YYYY-MM-DD)",
        "aa/pca ids and transition fields from anchor_transition",
        "aa_type join from anchor_scored.AA_Primary_Type"
      ]
    },
    {
      "filename": "ca_profile.csv",
      "required_columns": [
        "product_id",
        "ca_type",
        "attach_rate",
        "median_cart_size",
        "breadth_lift",
        "companion_count",
        "top1_share",
        "top3_share",
        "top1_companion_product_id"
      ],
      "rules": [
        "base metrics from cart_anchor",
        "ca_type from cart_anchor.CA_Primary_Type",
        "top1_companion_product_id from cart_anchor_detail pair with max(co_order_cnt)"
      ]
    },
    {
      "filename": "bii_window.csv",
      "required_columns": [
        "as_of_date",
        "window_days",
        "bii",
        "bhi",
        "clv_norm",
        "customer_strength_norm",
        "stage",
        "baseline_days",
        "confidence"
      ],
      "rules": [
        "window_days fixed to [7,30,90,365]",
        "bhi from brand_score.BHI or equivalent",
        "clv_norm and customer_strength_norm from fallback heuristics when raw absent",
        "bii = bhi * clv_norm * customer_strength_norm",
        "stage default Stable",
        "baseline_days default 365"
      ]
    },
    {
      "filename": "apf_action_rules.csv",
      "required_columns": [
        "rule_id",
        "domain",
        "condition_expr",
        "priority",
        "title_ko",
        "action_ko",
        "impact_ko"
      ],
      "rules": [
        "minimum 6 default rules (marketing 3, md 3)",
        "condition_expr supports simple metric comparisons with &&"
      ]
    }
  ],
  "constraints": {
    "rates_between_0_and_1": [
      "repeat_7d_rate",
      "repeat_30d_rate",
      "repeat_90d_rate",
      "pca_transition_30d_rate",
      "pca_transition_90d_rate",
      "transition_rate",
      "attach_rate",
      "top1_share",
      "top3_share"
    ],
    "monotonic_rates": [
      "repeat_7d_rate <= repeat_30d_rate <= repeat_90d_rate"
    ],
    "required_windows": [
      7,
      30,
      90,
      365
    ]
  }
}

